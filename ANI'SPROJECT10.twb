                    <run bold='true'>👤 </run>
                    <run bold='true' fontsize='10'>Customers with less than 1 year tenure are</run>
                    <run>Æ&#10;</run>
                    <run bold='true' fontsize='10'> high-risk</run>
                    <run>Æ&#10;&#10;</run>
                    <run bold='true'>📈 </run>
                    <run bold='true' fontsize='10'>Long-term contracts improve </run>
                    <run>Æ&#10;</run>
                    <run bold='true' fontsize='10'>retention</run>
                    <run>Æ&#10;&#10;</run>
                    <run bold='true'>🎯 </run>
